# Copy this file to .env.local and fill in real values from your Supabase
# project (Project Settings → API). Never commit .env.local — it's already
# git-ignored.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# From Kit (kit.com) → Settings → Advanced → API. Used server-side only, to
# pull newsletter content into the "Import from Kit" admin feature — never
# exposed to the browser.
KIT_API_KEY=

# Kit form IDs for the /find-my-membership quiz — one per result tier.
# Find via GET https://api.kit.com/v4/forms or the Kit dashboard form URL.
# Tagging requires infinity-quiz-free / infinity-quiz-practice /
# infinity-quiz-practitioner to already exist as tags in the Kit account.
KIT_FORM_FREE=
KIT_FORM_PRACTICE=
KIT_FORM_PRACTITIONER=
